# Example environment variables
# If you want to use the SQL Server database, set MSSQL_CONNECTION_STRING to a valid connection string
# Example: MSSQL_CONNECTION_STRING="Server=localhost,1433;Database=workout;User Id=sa;Password=Your_password123;TrustServerCertificate=true"

# If empty, the app will continue to use the bundled SQLite database at /data/users.db
MSSQL_CONNECTION_STRING=
# Copy this file to .env.local and fill in local environment values.
# Do NOT commit your real .env.local to version control.

# JWT secret for signing local session tokens (change before production)
JWT_SECRET=replace-with-a-random-secret
